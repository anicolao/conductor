# Conductor Observability UI Environment Variables
# These must start with PUBLIC_ to be accessible in the browser.

# The GitHub OAuth App Client ID
PUBLIC_GITHUB_CLIENT_ID=your_github_client_id_here

# The URL of the Firebase Function that handles the OAuth code exchange
# Local development: http://127.0.0.1:5001/llm-orch-conductor-bridge/us-central1/githubOAuthExchange
# Production: https://us-central1-llm-orch-conductor-bridge.cloudfunctions.net/githubOAuthExchange
PUBLIC_OAUTH_EXCHANGE_URL=http://127.0.0.1:5001/llm-orch-conductor-bridge/us-central1/githubOAuthExchange
