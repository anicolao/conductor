# Conductor Observability UI Environment Variables Example
# Copy this file to .env and fill in the values.
# NOTE: Variables prefixed with 'PUBLIC_' are exposed to the browser.

# GitHub OAuth App Client ID
# Where to get: GitHub Settings -> Developer settings -> OAuth Apps
PUBLIC_GITHUB_CLIENT_ID=your_github_client_id_here

# Firebase Function URL for OAuth code-to-token exchange
# Local dev (default emulator port): http://127.0.0.1:5001/llm-orch-conductor-bridge/us-central1/githubOAuthExchange
# Production: https://us-central1-llm-orch-conductor-bridge.cloudfunctions.net/githubOAuthExchange
PUBLIC_OAUTH_EXCHANGE_URL=http://127.0.0.1:5001/llm-orch-conductor-bridge/us-central1/githubOAuthExchange
