{
  "name": "conductor",
  "version": "0.1.0",
  "description": "LLM Coordination Framework",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "firebase:deploy": "npx --yes firebase-tools deploy --only functions",
    "firebase:serve": "npx --yes firebase-tools emulators:start --only functions",
    "handoff": "bash ./scripts/handoff.sh",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.3"
  }
}
