# Conductor Project - Root Environment Variables Example
# Copy this file to .env and fill in the values.

# ==============================================================================
# FRONTEND: Observability UI (SvelteKit)
# ==============================================================================
# Path: observability-ui/
# NOTE: Variables prefixed with 'PUBLIC_' are exposed to the browser.

# GitHub OAuth App Client ID
# Where to get: GitHub Settings -> Developer settings -> OAuth Apps
PUBLIC_GITHUB_CLIENT_ID=your_github_client_id_here

# Firebase Function URL for OAuth code-to-token exchange
# Local dev (default emulator port): http://127.0.0.1:5001/llm-orch-conductor-bridge/us-central1/githubOAuthExchange
# Production: https://us-central1-llm-orch-conductor-bridge.cloudfunctions.net/githubOAuthExchange
PUBLIC_OAUTH_EXCHANGE_URL=http://127.0.0.1:5001/llm-orch-conductor-bridge/us-central1/githubOAuthExchange


# ==============================================================================
# BACKEND: Firebase Functions
# ==============================================================================
# Path: functions/
# NOTE: These are SENSITIVE. Do NOT set them in .env for production.
# Use `firebase functions:secrets:set <KEY>` instead.
# The following are listed here only for reference of what needs to be configured.

# GITHUB_CLIENT_ID=your_github_client_id_here
# GITHUB_CLIENT_SECRET=your_github_client_secret_here


# ==============================================================================
# CLI / CORE: Conductor Agent
# ==============================================================================
# Path: src/ (Core logic and CLI)

# Google Gemini API Key
# Used by the conductor to interact with the LLM.
GEMINI_API_KEY=your_gemini_api_key_here
